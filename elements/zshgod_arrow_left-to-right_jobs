# Function which returns current amount of jobs if there at least 1 job
# Uses builtin %j to get number of jobs
function zshgod_arrow_left-to-right_jobs() {
	# Allow passing args to function for changing foreground and background colors
	local bg_color=$1
	local fg_color=$2

	print "%(1j,$(zshgod_generic arrow_left-to-right 'jobs: [%j]' $bg_color $fg_color),)"
}
