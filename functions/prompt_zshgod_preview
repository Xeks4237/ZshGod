# Function which is called to show simulated preview of prompt
# Can be used by running: prompt -p zshgod
prompt_zshgod_preview() {
	print 'ZshGod prompt with default theme:'
	print -P "%Bв”Ң%F{blue}оғ—%S %K{black}/some/path%k %sоӮ°%f%F{magenta}оғ—%S %K{black}git%k %sоӮ°%f%F{green}оғ—%S %K{black}main%k %sоӮ°%f%F{#6C7086}оғ—%S %K{green}1+%k %K{yellow}1*%k %K{red}1-%k %K{cyan}1?%k %K{magenta}1вҶ‘%k %sоӮ°%f%bв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ%Bв”җ%b"
	print -P "%Bв””%(!,%F{red}оғ—%S %K{black}#%k %sоӮ°%f,%F{green}оғ—%S %K{black}$%k %sоӮ°%f) %bcommand arg1 arg2 arg3 ...    %B%F{red}оӮІ%S %K{black}127%k %sоғ–%f%F{magenta}оӮІ%S %K{black}jobs: [69]%k %sоғ–%f%F{yellow}оӮІ%S %K{black}%D{%H:%M:%S}%k %sоғ–%fв”ҳ%b"
}
