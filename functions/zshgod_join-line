# Function which allows creating LEFT.......RIGHT string that fills the whole terminal line
# Uses zshgod_length-calculator to measure real printed width of both parts
# First argument sets LEFT
# Second argument sets RIGHT
# Third argument sets character/string which going to be used between LEFT and RIGHT
function zshgod_join-line() {
	local -i left_len=$(zshgod_length-calculator $1)

	local -i right_len=$(zshgod_length-calculator $2)

	local -i pad_len=$(( COLUMNS - left_len - right_len - ${ZLE_RPROMPT_INDENT:-1} ))

	if (( pad_len > 0 )); then
		local pad=${(pl.$pad_len..$3.)}
		typeset -g ZSHGOD_TOP_LINE=${1}${pad}${2}
	else
		typeset -g ZSHGOD_TOP_LINE=${1}
	fi
}
