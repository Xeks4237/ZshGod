# Function which returns branch/subversion info about current vcs
function zshgod_rectangular_vcs_branch() {
	# Allow passing args to function for changing foreground and background colors
	local bg_color=$1
	local fg_color=$2

	[[ -n $(zshgod_vcs_branch) ]] || return
	zshgod_generic rectangular "$(zshgod_vcs_branch)" "$bg_color" "$fg_color"
}
