# Function which returns current action of current vcs
function zshgod_arrow_left-to-right_vcs_action() {
	# Allow passing args to function for changing foreground and background colors
	local bg_color=$1
	local fg_color=$2

	[[ -n $(zshgod_vcs_action) ]] || return
	print "%F{$bg_color}%S %K{$fg_color}$(zshgod_vcs_action)%k %s%f"
}
