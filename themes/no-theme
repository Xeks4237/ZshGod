# [ Info about theme ]
# Author: Xeks4237
# Its a default user config used if user don't specifies other one.
# Configuration for zshgod which uses arrow elements and catppuccin mocha colors:
# https://github.com/catppuccin

# [ Configuration variables and Zstyle ]
# zstyle options to enable or disable some vcs which you don't use
# zstyle ':vcs_info:*' disable git svn
zstyle ':vcs_info:*' enable bzr cdv cvs darcs fossil git hg mtn p4 svk svn tla

# Variable which sets minimal amount of exectime after its shown
ZSHGOD_EXECTIME_MIN=5

# Left side of secondry prompt shown when writing multilined commands manually
# Expanded in same way as PS1
PS2='%B%F{magenta}%S %K{black}%_%k %s%f%b '

# Right side of secondry prompt shown when writing multilined commands manually
# Try to keep it empty to don't clutter view to multilined commands
# Expanded in same way as RPS1
RPS2=''

# Prompt used inside of select loop, expanded in same way as PS1
PS3='%B%F{magenta}%S %K{black}?#%k %s%f%b '

# Prompt shown when xtrace, sourcetrace, and etc logging options are set
PS4='%F{magenta}%N%f %F{yellow}%i%f%F{green}:%f '

# [ Functions used in prompt ]
# Autoload functions used in prompt
autoload -Uz \
	zshgod_arrow_left-to-right_current-pwd \
	zshgod_arrow_left-to-right_vcs_system \
	zshgod_arrow_left-to-right_vcs_branch \
	zshgod_arrow_left-to-right_git_info \
	zshgod_arrow_left-to-right_exectime_human-readable \
	zshgod_arrow_left-to-right_root-indicator \
	zshgod_arrow_right-to-left_ssh-only_userandhostname \
	zshgod_arrow_right-to-left_time \
	zshgod_arrow_right-to-left_jobs \
	zshgod_arrow_right-to-left_exit-code

# Array with functions and args for them which are used in main prompt
# This functions going to be used asynchronously in prompt
# And they will also create variables with same name as functions,
# but in uppercase and with _ instead of -
# For Example: ZsH_fOo-BoO => ZSH_FOO_BOO
ZSHGOD_USED_FUNCTIONS=(
	'zshgod_arrow_left-to-right_current-pwd blue black'
	'zshgod_arrow_left-to-right_vcs_system magenta black'
	'zshgod_arrow_left-to-right_vcs_branch green black'
	'zshgod_arrow_left-to-right_git_info "#6C7086" green yellow red cyan magenta'
	'zshgod_arrow_left-to-right_exectime_human-readable "$ZSHGOD_EXECTIME" yellow black'
	'zshgod_arrow_left-to-right_root-indicator green black red black'
	'zshgod_arrow_right-to-left_ssh-only_userandhostname green black red black yellow black blue black'
	'zshgod_arrow_right-to-left_time yellow black'
	'zshgod_arrow_right-to-left_jobs magenta black'
	'zshgod_arrow_right-to-left_exit-code red black'
)

# [ Zsh hook functions ]
# preexec function which gets called before every COMMAND
preexec() {
	# Function/Command to set title of the terminal
	zshgod_set-title -Pr '%~'
}

# precmd function which gets called after commands and before showing prompt
precmd() {
	# Function/Command to set title of the terminal
	zshgod_set-title -Pr '%1~: $2'
}

# [ Main prompt ]
# Lines below will set prompt accordingly:
#  $ZSHGOD_TOP_LEFT......<$ZSHGOD_FILLER>......$ZSHGOD_TOP_RIGHT
#  $ZSHGOD_BOTTOM_LEFT                      $ZSHGOD_BOTTOM_RIGHT

# Variable which sets character/string which be used between left and right of prompts top line
ZSHGOD_FILLER='─'

# Array with items of main prompts top left side
ZSHGOD_TOP_LEFT=(
	'%B'
	'┌'
	'$ZSHGOD_ARROW_LEFT_TO_RIGHT_CURRENT_PWD'
	'$ZSHGOD_ARROW_LEFT_TO_RIGHT_VCS_SYSTEM'
	'$ZSHGOD_ARROW_LEFT_TO_RIGHT_VCS_BRANCH'
	'$ZSHGOD_ARROW_LEFT_TO_RIGHT_GIT_INFO'
	'$ZSHGOD_ARROW_LEFT_TO_RIGHT_EXECTIME_HUMAN_READABLE'
	'%b'
)

# Array with items of main prompts bottom left side
ZSHGOD_BOTTOM_LEFT=(
	'%B'
	'└'
	'$ZSHGOD_ARROW_LEFT_TO_RIGHT_ROOT_INDICATOR'
	' '
	'%b'
)

# Array with items of main prompts top right side
ZSHGOD_TOP_RIGHT=(
	'%B'
	'$ZSHGOD_ARROW_RIGHT_TO_LEFT_SSH_ONLY_USERANDHOSTNAME'
	'$ZSHGOD_ARROW_RIGHT_TO_LEFT_TIME'
	'%b'
)

# Array with items of main prompts bottom right side
ZSHGOD_BOTTOM_RIGHT=(
	'%B'
	'$ZSHGOD_ARROW_RIGHT_TO_LEFT_JOBS'
	'$ZSHGOD_ARROW_RIGHT_TO_LEFT_EXIT_CODE'
	'%b'
)
