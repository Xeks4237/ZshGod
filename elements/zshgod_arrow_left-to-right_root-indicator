# Function which shows colored arrow with different color if current user is root
function zshgod_arrow_left-to-right_root-indicator () {
	# Allow passing args to function for changing foreground and background colors
	local user_bg_color=$1
	local user_fg_color=$2
	local root_bg_color=$3
	local root_fg_color=$4

	print "%(!,$(zshgod_generic arrow_left-to-right '#' $root_bg_color $root_fg_color),$(zshgod_generic arrow_left-to-right '$' $user_bg_color $user_fg_color))"
}
