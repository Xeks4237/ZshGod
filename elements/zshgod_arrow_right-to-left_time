# Function for showing arrow with customly formatted current time
function zshgod_arrow_right-to-left_time() {
	# Allow passing args to function for changing foreground and background colors
	local bg_color=$1
	local fg_color=$2

	zshgod_generic arrow_right-to-left '%D{%H:%M:%S}' "$bg_color" "$fg_color"
}
