# Function which is registered as callback function for async workers
# of zshgod prompt, when async worker finishes running it outputs results
# to this function as arguments where:
# First argument is th name of the function which was runned
# Second argument is the return code of the function which was runned
# Third argument is the output(stdout) of the function which was runned
# Fourt argument is the execution time of the function which was runned
# Fifth argument is the error output(stderr) of the function which was runned
# Sixth argument has next result in buffer (0 = buffer empty, 1 = yes)
function zshgod_async-callback() {
	# Local variables for each argument
	local job_name=$1 exit_code=$2 output=$3 exec_time=$4 stderr=$5 next=$6

	# Case statement to check if there are errors with worker
	case $job_name in
	\[async])
			# Handle all the errors that could indicate a crashed async worker
			# See zsh-async documentation for the definition of the exit codes.
			[[ $exit_code == 1 || $exit_code == 2 || $exit_code == 3 || $exit_code == 130 ]] && async_stop_worker zshgod_async_worker
			;;

			# Handler for case in async_worker_eval failed
		\[async/eval])
			[[ $exit_code ]] && async_stop_worker zshgod_async_worker
			;;
	esac

	# Dynamically create new variable based on the function name in $job_name
	# and then put value in $output to the newly created variable
	# For example $job_name with zsh_git-info will create variable ZSH_GIT_INFO
	local varname="${${job_name//-/_}:u}"
	typeset -g "${varname}"="${output}"

	# [ Building prompt ]
	# Join elements of the arrays to don't have extra spaces between them
	local top_left="${(j::)ZSHGOD_TOP_LEFT}"
	local top_right="${(j::)ZSHGOD_TOP_RIGHT}"
	local bottom_left="${(j::)ZSHGOD_BOTTOM_LEFT}"
	local bottom_right="${(j::)ZSHGOD_BOTTOM_RIGHT}"

	# Combine left and right side in to one line with alighment of right side,
	# Using $ZSHGOD_FILLER as repeting string between them
	zshgod_join-line "$top_left" "$top_right" "$ZSHGOD_FILLER"

	# And set prompt using newly created variables.
	# Lines below will set prompt accordingly:
	#  $ZSHGOD_TOP_LEFT.....<$ZSHGOD_FILLER>....$ZSHGOD_TOP_RIGHT
	#  $ZSHGOD_BOTTOM_LEFT                   $ZSHGOD_BOTTOM_RIGHT
	PS1=$ZSHGOD_TOP_LINE$prompt_newline$bottom_left
	RPS1=$bottom_right

	# Activate zle and Redisplay/Update prompt
	zle && zle redisplay; zle reset-prompt
}
