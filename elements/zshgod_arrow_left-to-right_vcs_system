# Function which returns name of current vcs
function zshgod_arrow_left-to-right_vcs_system() {
	# Allow passing args to function for changing foreground and background colors
	local bg_color=$1
	local fg_color=$2

	[[ -n $(zshgod_vcs_system) ]] || return
	zshgod_generic arrow_left-to-right "$(zshgod_vcs_system)" "$bg_color" "$fg_color"
}
