# Function where all other functions are used to make prompt
# INFO: This function is called when you choose prompt using 'prompt' command
# This functions name is important it should be 'prompt_<name_of_prompt>_setup'
# And this function also accepts args through 'prompt' command, like:
# prompt zshgod --min-exectime=5
function prompt_zshgod_setup() {
	# [ Prompt specific opts and Hooks for Functions ]
	# Sets prompt specific zsh opts like prompt substitution
	prompt_opts=( bang cr percent sp subst )

	# Ensures that variable $prompt_newline is availible
	# This variable needs to be set, usually set by promptinit
	[[ -z $prompt_newline ]] && typeset -g prompt_newline=$'\n%{\r%}'

	# Load zsh modules used in prompt
	zmodload zsh/datetime
	zmodload zsh/zle
	zmodload zsh/parameter
	zmodload zsh/zutil

	# Load Zsh module related to zsh hooks
	autoload -Uz add-zsh-hook

	# Load Zsh module related to zsh line editor hooks
	autoload -Uz add-zle-hook-widget

	# Builtin zsh module for getting basic info from vcs systems
	autoload -Uz vcs_info

	# Source zsh-async library
	source "$ZSHGOD_HOME/functions/async"

	# Initialize zsh-async library
	async

	# Autoload generally needed functions which are used in prompt
	# Autoloading allows to have only used functions in memory
	# INFO: availible functions are mentioned in help message of prompt: prompt -h zshgod
	# WARN: Always use '-Uz' to supress alias expansion and to use zsh styly autoloading
	autoload -Uz \
		prompt_zshgod_precmd \
		prompt_zshgod_preexec \
		prompt_zshgod_chpwd \
		prompt_zshgod_preview \
		prompt_zshgod_help \
		zshgod_set-title \
		zshgod_length-calculator \
		zshgod_middle-line \
		zshgod_generic \
		zshgod_vcs_system \
		zshgod_vcs_branch \
		zshgod_vcs_action \
		zshgod_vi-mode \
		zshgod_async-callback \
		zshgod_vimode \
		zshgod_configure

	# Declare empty precmd and preexec functions used in themes
	zshgod_theme_precmd() {}
	zshgod_theme_preexec() {}

	# Add preexec hook which gets called before running any COMMAND to some functions
	add-zsh-hook preexec prompt_zshgod_preexec
	add-zsh-hook preexec zshgod_theme_preexec

	# Add precmd hook which gets called before showing prompt to some functions
	add-zsh-hook precmd prompt_zshgod_precmd
	add-zsh-hook precmd zshgod_theme_precmd

	# Add chpwd hook which gets called after current working directory changes to some function
	add-zsh-hook chpwd prompt_zshgod_chpwd

	# Add zle hoom to zshgod_refresh function to be call it in certain cases needed for vimode elements
	# TODO: I should make more efficient way to run than
	# add-zle-hook-widget zle-line-pre-redraw zshgod_refresh

	# [ Default valies for variables ]
	# Variable which sets minimal amount of exectime after its shown
	ZSHGOD_EXECTIME_MIN=5

	# Prevent percentage showing up if output doesn't end with a newline
	PROMPT_EOL_MARK=''

	# Unset variable to prevent Oh-My-Zsh from overwriting prompt
	unset ZSHGOD_THEME

	# [ Handling args ]
	# Cycle through passed args/flags to function to make easy and fast configuration
	for arg in "$@"; do
		case "$arg" in
				# SubCommand open simple configuration wizard/editor
			configure)
				zshgod_configure
				return
				;;

				# SubCommand to display help page of prompt
				# NOTE: Help page of prompt can also be shown by running: prompt -h zshgod
			-h|--help|help)
				prompt -h zshgod
				return
				;;

				# SubCommand to list all currently availible themes
			themes)
				ls --color=never --almost-all --format=single-column "$ZSHGOD_HOME/themes/"
				return
				;;

				# Flag to specify theme or config file for prompt
			--theme=*)
				# Check if given theme is the path to config file or theme name
				local theme="${arg#--theme=}"
				if [[ -r $theme ]]; then
					source "$theme"
					ZSHGOD_THEME="$theme"
				elif [[ -r "$ZSHGOD_HOME/themes/$theme" ]]; then
					source "$ZSHGOD_HOME/themes/$theme"
					ZSHGOD_THEME="$theme"
				else
					unset ZSHGOD_THEME
					print -Pu2 "%F{red}Error:%f %F{yellow}Bad value for%f %F{green}--theme%f %F{yellow}flag:%f %F{blue}$theme%f"
				fi
				;;

				# Flag to set minimal threshold for displaying exectime
			--min-exectime=*)
				export ZSHGOD_EXECTIME_MIN="${arg#--min-exectime=}"
				;;

				# Hardlers for weird scenarios
			--*)
				print -Pu2 "%F{red}Unknown option(s):%f %F{yellow}$arg%f" >&2
				return 1
				;;

			*)
				print -Pu2 "%F{red}Unknown option(s):%f %F{yellow}$arg%f" >&2
				return 1
				;;
		esac
	done
	# Set up default config for prompt if --theme wasn't used
	[[ -n $ZSHGOD_THEME ]] || source "$ZSHGOD_HOME/themes/default" && ZSHGOD_THEME='default'
}
