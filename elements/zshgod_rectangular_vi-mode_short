# Function/Element which shows current vi mode of command line
# NOTE: This function should not be called with async, because it
# doesn't needs that and also it should be added to prompt theme/file
# like literal string of '$(zshgod_rectangular_vi-mode_short)'
function zshgod_rectangular_vi-mode_short() {
	# Allow passing args to function for changing foreground and background colors
	local fg_color=$1
	local bg_color_insert=$2
	local bg_color_normal=$3
	local bg_color_visual=$4
	local bg_color_v_line=$5
	local bg_color_replace=$6

	local vimode="$(zshgod_vi-mode)"

	if [[ $vimode == 'INSERT' ]]; then
		print "%F{$fg_color}%K{$bg_color_insert} I %k%f"
	elif [[ $vimode == 'NORMAL' ]]; then
		print "%F{$fg_color}%K{$bg_color_normal} N %k%f"
	elif [[ $vimode == 'VISUAL' ]]; then
		print "%F{$fg_color}%K{$bg_color_visual} V %k%f"
	elif [[ $vimode == 'V-LINE' ]]; then
		print "%F{$fg_color}%K{$bg_color_v_line} L %k%f"
	elif [[ $vimode == 'REPLACE' ]]; then
		print "%F{$fg_color}%K{$bg_color_replace} R %k%f"
	else
		print "%F{$fg_color}%K{$bg_color_normal} ? %k%f"
	fi
}
