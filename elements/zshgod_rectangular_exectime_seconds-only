# Function which returns exectime for commands after it's been called
function zshgod_rectangular_exectime_seconds-only() {
	# Allow passing args to function for changing foreground and background colors
	local time=$1
	local bg_color=$2
	local fg_color=$3

	# Check if exectime isn't empty and output exectime
	[[ -n $time ]] && zshgod_generic rectangular "${time}s" "$bg_color" "$fg_color"
}
