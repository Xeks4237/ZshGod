# Generic function which allows putting given to it info, style, and colors in to custom element
function zshgod_generic() {
	local style=$1
	local info=$2
	local bg_color=$3
	local fg_color=$4

	case $style in
		text)
			print "%F{$fg_color}$info%f"
			;;
		rectangular)
			print "%F{$fg_color}%K{$bg_color} $info %k%f"
			;;
		left-to-right_arrow)
			print "%F{$bg_color}îƒ—%S %K{$fg_color}$info%k %sî‚°%f"
			;;
		right-to-left_arrow)
			print "%F{$bg_color}î‚²%S %K{$fg_color}$info%k %sîƒ–%f"
			;;
	esac
}
