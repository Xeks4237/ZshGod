# Function which gets called after running command finishes and before prompt is drown
# INFO: This function gets unset automatically when you change to another prompt/theme
function prompt_zshgod_precmd() {
	# [ Parts of other functions which need precmd ]
	# Snippet used for calculating exectime of commands
	if (( ${+ZSHGOD_EXECTIME_START} )); then
		# Calculate exectime
		ZSHGOD_EXECTIME=$(( EPOCHSECONDS - ZSHGOD_EXECTIME_START ))

		# Check if exectime is bigger or equal to $ZSHGOD_EXECTIME_MIN
		# Its needed to customize minimal amount of seconds to show,
		# Like show exectime only if more then 5 seconds passed
		# Also if $ZSHGOD_EXECTIME_MIN is not set, default to 5
		(( ZSHGOD_EXECTIME >= ${ZSHGOD_EXECTIME_MIN:-5} )) || unset ZSHGOD_EXECTIME

		# Unset start time variable after calculating exectime
		unset ZSHGOD_EXECTIME_START
	else
		# Unset exectime variable if starting time for exectime is not set
		unset ZSHGOD_EXECTIME
	fi

	# [ Async jobs ]
	# Cycle through and run all functions in
	# $ZSHGOD_USED_FUNCTIONS array asynchronously
	for async_work in "${ZSHGOD_USED_FUNCTIONS[@]}"; do
		# Start new async worker
		async_start_worker zshgod_async_worker -n 2> /dev/null

		# Register its callback function
		async_register_callback zshgod_async_worker zshgod_async-callback

		# Run async job
		async_job zshgod_async_worker "$async_work"
	done

	# [ Building prompt ]
	# Join elements of the arrays to don't have extra spaces between them
	local top_left="${(j::)ZSHGOD_TOP_LEFT}"
	local top_right="${(j::)ZSHGOD_TOP_RIGHT}"
	local bottom_left="${(j::)ZSHGOD_BOTTOM_LEFT}"
	local bottom_right="${(j::)ZSHGOD_BOTTOM_RIGHT}"

	# Combine left and right side in to one line with alighment of right side,
	# using $ZSHGOD_FILLER as repeting string between them
	local ZSHGOD_TOP_LINE
	zshgod_join-line "$top_left" "$top_right" "$ZSHGOD_FILLER"

	# And set prompt using newly created variables.
	# Lines below will set prompt accordingly:
	#  $ZSHGOD_TOP_LEFT.....<$ZSHGOD_FILLER>....$ZSHGOD_TOP_RIGHT
	#  $ZSHGOD_BOTTOM_LEFT                   $ZSHGOD_BOTTOM_RIGHT
	PS1=$ZSHGOD_TOP_LINE$prompt_newline$bottom_left
	RPS1=$bottom_right
}
